JUPITER_API_KEY=your-jupiter-api-key
JUPITER_API_BASE_URL=https://api.jup.ag/swap/v2
BRIDGE_WEBHOOK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nyour-bridge-webhook-public-key\n-----END PUBLIC KEY-----
BRIDGE_WEBHOOK_MAX_AGE_MS=600000
OUTBOUND_REQUEST_RETRIES=1
OUTBOUND_REQUEST_TIMEOUT_MS=8000
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=10000
PG_POOL_CONNECTION_TIMEOUT_MS=3000
PG_POOL_MAX_LIFETIME_SECONDS=300
