PORT=4000
ALLOWED_ORIGINS=http://localhost:3000,https://app.monra.io
DATABASE_URL=postgres://postgres:postgres@localhost:5432/monra
ALCHEMY_API_KEY=your-alchemy-api-key
ALCHEMY_WEBHOOK_ID=your-alchemy-webhook-id
ALCHEMY_WEBHOOK_AUTH_TOKEN=your-alchemy-webhook-auth-token
ALCHEMY_WEBHOOK_SIGNING_KEY=your-alchemy-webhook-signing-key
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
BRIDGE_API_KEY=your-bridge-api-key
